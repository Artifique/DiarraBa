// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  nom               String
  email             String         @unique
  password          String
  role              String         @default("gerant") // "admin" ou "gerant"
  telephone         String
  date_creation     DateTime       @default(now())
  date_modification DateTime       @updatedAt
  audits            Audit[]
  settings          Setting[]
  notifications     Notification[]
}

model Personne {
  id                String        @id @default(uuid())
  type              String // "client" ou "fournisseur"
  nom               String?
  adresse           String?
  telephone         String        @unique
  date_creation     DateTime      @default(now())
  date_modification DateTime      @updatedAt
  reservations      Reservation[] @relation("ClientReservations")
  produitsFournis   Produit[]     @relation("FournisseurProduits")
}

model Categorie {
  id                String    @id @default(uuid())
  nomCategorie      String    @unique
  date_creation     DateTime  @default(now())
  date_modification DateTime  @updatedAt
  produits          Produit[]
}

model Produit {
  id                String             @id @default(uuid())
  nom               String
  prix_achat        Float?
  quantite          Int
  prix_unitaire     Float
  categorieId       String
  fournisseurId     String? // Facultatif selon la description
  date_creation     DateTime           @default(now())
  date_modification DateTime           @updatedAt
  categorie         Categorie          @relation(fields: [categorieId], references: [id])
  fournisseur       Personne?          @relation("FournisseurProduits", fields: [fournisseurId], references: [id])
  lignesReservation LigneReservation[]
}

model Reservation {
  id                String             @id @default(uuid())
  clientId          String
  date_reservation  DateTime           @default(now()) // date_aujourdhui
  date_finale       DateTime // date_finale_reservation
  mode_paiement     String? // facultatif
  methode_paiement  String // "totalité" ou "par tranche"
  montant_total     Float // calculé
  date_creation     DateTime           @default(now())
  date_modification DateTime           @updatedAt
  client            Personne           @relation("ClientReservations", fields: [clientId], references: [id])
  paiements         Paiement[]
  lignes            LigneReservation[]
  facture           Facture?
}

model LigneReservation {
  id                String      @id @default(uuid())
  reservationId     String
  produitId         String
  quantite          Int
  prix_unitaire     Float
  reservation       Reservation @relation(fields: [reservationId], references: [id])
  produit           Produit     @relation(fields: [produitId], references: [id])
  date_creation     DateTime    @default(now())
  date_modification DateTime    @updatedAt
}

model Paiement {
  id                String      @id @default(uuid())
  reservationId     String
  montant           Float
  date_paiement     DateTime    @default(now())
  mode_paiement     String? // ex: espèces, carte, virement
  date_creation     DateTime    @default(now())
  date_modification DateTime    @updatedAt
  reservation       Reservation @relation(fields: [reservationId], references: [id])
}

model Eclosion {
  id                String   @id @default(uuid())
  telephone         String
  quantite          Int
  date_debut        DateTime @default(now()) // date du jour
  date_fin_prevue   DateTime
  prix              Float
  paye              Boolean  @default(false) // Payer type Bool
  date_creation     DateTime @default(now())
  date_modification DateTime @updatedAt
}

model Facture {
  id                String      @id @default(uuid())
  reservationId     String      @unique
  numero            String      @unique
  date_facture      DateTime    @default(now())
  montant_total     Float
  montant_paye      Float
  montant_restant   Float
  statut            String
  date_creation     DateTime    @default(now())
  date_modification DateTime    @updatedAt
  reservation       Reservation @relation(fields: [reservationId], references: [id])
}

model Notification {
  id                String   @id @default(uuid())
  message           String
  type              String // ex: "stock_faible", "rappel_eclosion"
  entity_id         String? // id de l'entité concernée (produit, eclosion)
  read              Boolean  @default(false)
  date_creation     DateTime @default(now())
  date_modification DateTime @updatedAt
  userId            String // Notification liée à un utilisateur
  user              User     @relation(fields: [userId], references: [id])
}

model Audit {
  id                String   @id @default(uuid())
  userId            String
  action            String // ex: "CREATE", "UPDATE", "DELETE"
  entity_type       String // ex: "Produit", "Reservation", "User"
  entity_id         String
  old_value         Json?
  new_value         Json?
  ip_address        String?
  user_agent        String?
  date_creation     DateTime @default(now())
  date_modification DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}

model Setting {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String
  type              String // "boolean", "number", "string"
  description       String?
  userId            String // Paramètre lié à un utilisateur
  user              User     @relation(fields: [userId], references: [id])
  date_creation     DateTime @default(now())
  date_modification DateTime @updatedAt
}
